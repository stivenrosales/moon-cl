# --- Postgres (Neon) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="changeme"
AUTH_URL="http://localhost:3000"

# --- Email (Resend recomendado) ---
# Crea una API key en https://resend.com
AUTH_RESEND_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="Moon Club <noreply@tudominio.com>"

# Alternativa: SMTP clásico (descomentar si no usas Resend)
# EMAIL_SERVER_HOST="smtp.example.com"
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER="user"
# EMAIL_SERVER_PASSWORD="pass"

# --- Admins iniciales ---
# Lista de emails separada por comas. Estos usuarios serán ADMIN automáticamente.
ADMIN_EMAILS="tu@email.com"

# --- Google Books (opcional, sin key tiene rate limit) ---
GOOGLE_BOOKS_API_KEY=""
