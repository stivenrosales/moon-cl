generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (NextAuth / Auth.js)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  role           Role      @default(MEMBER)
  bio            String?
  birthday       DateTime? @db.Date
  favoriteGenres String[]  @default([])
  ageConfirmedAt DateTime?
  onboardedAt    DateTime?
  isMatchOptIn   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  suggestions       BookSuggestion[]
  votes             Vote[]
  comments          Comment[]
  ratings           Rating[]
  rsvps             Rsvp[]
  progressUpdates   ReadingProgress[]
  createdRounds     Round[]           @relation("RoundCreator")
  createdMeetings   Meeting[]         @relation("MeetingCreator")
  userBooks         UserBook[]
  following         Follow[]          @relation("UserFollows")
  followers         Follow[]          @relation("UserFollowedBy")
  quotes            Quote[]
  quoteLikes        QuoteLike[]
  sentMessages      Message[]         @relation("MessageSender")
  receivedMessages  Message[]         @relation("MessageReceiver")
  createdActivities KahootActivity[]  @relation("KahootActivityCreator")
  kahootScores      KahootScore[]
  blocking          Block[]           @relation("UserBlocks")
  blockedBy         Block[]           @relation("UserBlockedBy")
  reportsMade       Report[]          @relation("ReportReporter")
  reportsReceived   Report[]          @relation("ReportReported")
  reportsResolved   Report[]          @relation("ReportResolver")
  matchesAsUserA    Match[]           @relation("MatchUserA")
  matchesAsUserB    Match[]           @relation("MatchUserB")
  nudges            UserNudge[]
}

enum Role {
  ADMIN
  MODERATOR
  MEMBER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Dominio del club
// ─────────────────────────────────────────────────────────────────────────────

model Book {
  id            String     @id @default(cuid())
  title         String
  authors       String[]
  categories    String[]   @default([])
  coverUrl      String?
  description   String?    @db.Text
  pageCount     Int?
  publishedYear Int?
  googleBooksId String?    @unique
  isbn          String?
  status        BookStatus @default(SUGGESTED)
  isCurrent     Boolean    @default(false)
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  suggestions     BookSuggestion[]
  comments        Comment[]
  ratings         Rating[]
  progressUpdates ReadingProgress[]
  meetings        Meeting[]
  wonRound        Round?            @relation("RoundWinner")
  userBooks       UserBook[]
  quotes          Quote[]

  @@index([isCurrent])
}

enum BookStatus {
  SUGGESTED // sugerido en alguna ronda, sin estado especial
  CURRENT // libro en curso del club
  FINISHED // ya leído por el club
  ARCHIVED // perdió la votación, queda en historial
}

model Round {
  id           String      @id @default(cuid())
  title        String
  description  String?     @db.Text
  startsAt     DateTime
  endsAt       DateTime
  status       RoundStatus @default(SCHEDULED)
  winnerBookId String?     @unique
  creatorId    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  winner      Book?            @relation("RoundWinner", fields: [winnerBookId], references: [id])
  creator     User?            @relation("RoundCreator", fields: [creatorId], references: [id])
  suggestions BookSuggestion[]

  @@index([status])
}

enum RoundStatus {
  SCHEDULED
  OPEN
  CLOSED
}

model BookSuggestion {
  id        String   @id @default(cuid())
  roundId   String
  bookId    String
  userId    String
  pitch     String?  @db.Text
  createdAt DateTime @default(now())

  round Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  book  Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes Vote[]

  @@unique([roundId, bookId])
  @@index([roundId])
}

model Vote {
  id           String   @id @default(cuid())
  suggestionId String
  userId       String
  createdAt    DateTime @default(now())

  suggestion BookSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@index([suggestionId])
}

model Comment {
  id           String    @id @default(cuid())
  bookId       String
  userId       String
  parentId     String?
  content      String    @db.Text
  isSpoiler    Boolean   @default(false)
  isReflection Boolean   @default(false)
  chapter      Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  book    Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([bookId])
  @@index([parentId])
}

model Rating {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  stars     Int
  review    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookId, userId])
  @@index([bookId])
}

model ReadingProgress {
  id          String   @id @default(cuid())
  bookId      String
  userId      String
  currentPage Int
  chapter     Int?
  note        String?
  createdAt   DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookId, userId])
  @@index([userId])
}

model Meeting {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  bookId      String?
  type        MeetingType @default(REUNION)
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  meetingUrl  String?
  isVirtual   Boolean     @default(false)
  remindedAt  DateTime?
  creatorId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  book             Book?            @relation(fields: [bookId], references: [id], onDelete: SetNull)
  creator          User?            @relation("MeetingCreator", fields: [creatorId], references: [id])
  rsvps            Rsvp[]
  kahootActivities KahootActivity[]

  @@index([startsAt])
}

enum MeetingType {
  REUNION
  CINE
  POESIA
  OTRO
}

model Rsvp {
  id        String     @id @default(cuid())
  meetingId String
  userId    String
  status    RsvpStatus
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
}

enum RsvpStatus {
  YES
  NO
  MAYBE
}

model UserBook {
  id             String      @id @default(cuid())
  userId         String
  bookId         String
  status         ShelfStatus
  currentPage    Int?
  currentChapter Int?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, status])
}

enum ShelfStatus {
  READING
  WANT_TO_READ
  FINISHED
}

// ─────────────────────────────────────────────────────────────────────────────
// Lote 3 — pendiente de aplicar a producción (ver docs/MIGRATIONS.md, sección 7)
// ─────────────────────────────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  // La regla anti-auto-follow (followerId !== followingId) se valida en la
  // server action: Prisma no soporta check constraints portables.
  follower  User @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowedBy", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Quote {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  content   String   @db.Text
  page      Int?
  chapter   Int?
  createdAt DateTime @default(now())

  book  Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes QuoteLike[]

  @@index([bookId])
  @@index([userId])
}

model QuoteLike {
  id        String   @id @default(cuid())
  quoteId   String
  userId    String
  createdAt DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quoteId, userId])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  content    String    @db.Text
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  // El código de DMs (bandeja, envío, marcar leído) llega en la próxima
  // tanda; el schema va ahora para agrupar el db push con el resto del lote.
  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, readAt])
}

model KahootActivity {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  playedAt    DateTime
  meetingId   String?
  creatorId   String?
  createdAt   DateTime @default(now())

  meeting Meeting?      @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  creator User?         @relation("KahootActivityCreator", fields: [creatorId], references: [id])
  scores  KahootScore[]

  @@index([meetingId])
  @@index([creatorId])
}

model KahootScore {
  id             String   @id @default(cuid())
  activityId     String
  userId         String
  points         Int
  correctAnswers Int?
  createdAt      DateTime @default(now())

  activity KahootActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Lote 4 — pendiente de aplicar a producción (ver docs/MIGRATIONS.md, sección 8)
// ─────────────────────────────────────────────────────────────────────────────

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model Report {
  id             String       @id @default(cuid())
  reporterId     String
  reportedUserId String
  category       String
  subReason      String?
  details        String?      @db.Text
  // Referencia débil: sin FK dura hacia Message para no impedir el borrado
  // de mensajes reportados. La UI resuelve el contenido del mensaje al
  // momento de mostrar el reporte; si el mensaje ya no existe, se muestra
  // el reporte igual (sin el contenido).
  messageId      String?
  status         ReportStatus @default(OPEN)
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?
  resolvedById   String?

  reporter     User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User  @relation("ReportReported", fields: [reportedUserId], references: [id], onDelete: Cascade)
  resolvedBy   User? @relation("ReportResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([reportedUserId])
}

model Match {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  weekOf    DateTime @db.Date
  score     Int
  createdAt DateTime @default(now())

  userA User @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId, weekOf])
  @@index([weekOf])
}

model UserNudge {
  id          String    @id @default(cuid())
  userId      String
  key         String
  payload     Json?
  dismissedAt DateTime?
  actedAt     DateTime?
  reason      String? // 'pre-existing' para las filas del backfill
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}
